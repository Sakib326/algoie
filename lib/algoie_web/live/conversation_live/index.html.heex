<Layouts.dashboard
  flash={@flash}
  current_user={@current_user}
  tenant={@tenant}
  store_id={@store_id}
  store_name={@store_name}
  user_stores={@user_stores}
  page_title={@page_title}
  active={:conversations}
>
  <.page_header title="Conversations">
    <:subtitle>Customer messaging across your channels.</:subtitle>
  </.page_header>

  <.panel>
    <.empty_state
      icon="hero-chat-bubble-left-right"
      title="Conversations are coming soon"
      description="Unified customer messaging and conversation management will live here. This module is planned for an upcoming release."
    />
  </.panel>
</Layouts.dashboard>
