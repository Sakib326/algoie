<Layouts.storefront flash={@flash}>
  <div class="text-center py-16">
    <h1 class="text-4xl font-bold mb-4">Welcome to our store</h1>
    <p class="text-lg text-base-content/70 mb-8">Browse our products and find what you need.</p>
    <.button navigate={~p"/products"} class="btn-primary btn-lg">
      View Products
    </.button>
  </div>
</Layouts.storefront>
